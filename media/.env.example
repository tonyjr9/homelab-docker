# Media Services (Transmission) - Environment Variables
# Copy to .env in this directory and update with your values

# Paths
MEDIA_PATH=/mnt/media

# User IDs
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Lisbon

# ========== Optional: Radarr & Sonarr API Keys ==========
# Get API keys from Radarr/Sonarr settings
# RADARR_API_KEY=your_radarr_api_key_here
# SONARR_API_KEY=your_sonarr_api_key_here
