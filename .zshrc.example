# Homelab Zsh Aliases & Functions

# Reload: source ~/.zshrc

# Docker
alias dc='docker compose'
alias dps='docker ps'
alias dlogs='docker logs -f --tail 50'
alias dprune='docker system prune -f'

# Homelab
alias homelab='cd $CONFIG_PATH'
alias manage='sudo $CONFIG_PATH/manage.sh'

# Quick services
alias proxy-up='cd $CONFIG_PATH/proxy && dc up -d'

# UFW
alias ufwstat='sudo ufw status verbose'

# Disk
alias diskuse='du -sh $MEDIA_PATH/* | sort -hr'

# Add more as needed