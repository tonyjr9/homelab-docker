# Nextcloud Stack - Environment Variables
# Copy nextcloud.env.example to nextcloud.env and update with your values
# NOTE: Use nextcloud.env for this service (separate from .env)

# Timezone
TZ=Europe/Lisbon

# User IDs
PUID=1000
PGID=1000

# ========== MySQL/MariaDB ==========
MYSQL_ROOT_PASSWORD=root_password_change_me_to_strong_password
MYSQL_PASSWORD=nextcloud_db_password_change_me_to_strong_password

# ========== Redis Cache ==========
REDIS_PASSWORD=redis_password_change_me_to_strong_password

# ========== Nextcloud ==========
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=admin_password_change_me_to_strong_password
