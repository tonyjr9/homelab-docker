# Global Environment Variables for Homelab Docker Stack
# Copy to .env and update with your specific values
# WARNING: .env is not tracked in Git - keep secrets here

# Paths
CONFIG_PATH=/opt/docker
MEDIA_PATH=/mnt/media

# Networking
DOCKER_SERVER_IP=192.168.0.102
NPM_IP=192.168.0.198
PIHOLE_IP=192.168.0.198

# Timezone (TZ database format)
TZ=Europe/Lisbon

# User IDs for container permissions
PUID=1000
PGID=1000

# ========== Pi-hole ==========
PIHOLE_PASSWORD=change_me_to_strong_password

# ========== Dynamic DNS (DuckDNS) ==========
DUCKDNS_DOMAIN=your-subdomain.duckdns.org
DUCKDNS_TOKEN=your_duckdns_token_here

# ========== Nextcloud Stack ==========
MYSQL_ROOT_PASSWORD=root_password_change_me
MYSQL_PASSWORD=nextcloud_db_password_change_me
REDIS_PASSWORD=redis_password_change_me
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=admin_password_change_me

# ========== Homarr ==========
HOMARR_SECRET_KEY=your_unique_secret_key_here

# ========== Media Services (Optional) ==========
# RADARR_API_KEY=your_radarr_api_key
# SONARR_API_KEY=your_sonarr_api_key
# PLEX_CLAIM=claim-xxxxxxxxxxxx

# ========== Minecraft (Optional) ==========
# MINECRAFT_EULA=true
# MINECRAFT_MEMORY=2G
# MINECRAFT_DIFFICULTY=2
