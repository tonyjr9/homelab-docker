# Minecraft Java Server - Environment Variables
# Copy to .env in this directory and update with your values

# User IDs
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Lisbon

# ========== Minecraft Server ==========
MINECRAFT_EULA=true
MINECRAFT_VERSION=latest
MINECRAFT_MEMORY=2G
MINECRAFT_DIFFICULTY=2
MINECRAFT_MODE=survival
MINECRAFT_VIEW_DISTANCE=10
MINECRAFT_MOTD=Welcome to Minecraft!
MINECRAFT_SPAWN_PROTECTION=16
MINECRAFT_PVP=true
