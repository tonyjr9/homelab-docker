# =============================================================================
# ALLOW ESSENTIAL FILES
# =============================================================================
# Explicitly include important files
!docker-compose.yml
!**/docker-compose.yml
!README.md
!**/README.md
!.env.example
!**/.env.example
!prometheus.yml
!**/prometheus.yml

# Allow empty config directories with .gitkeep
!**/.gitkeep

