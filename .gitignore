# Updated .gitignore including all data directories and .env files

# OpenVPN data
vpn/openvpn-data

# Environment variables and secrets
.env
.env.local
.env.*.local
*.env
.env.example  # Keep example tracked, but local .env ignored
env.sh

# Database files
*.db
*.sqlite
*.sqlite3
*.sql
*.sql.gz

# SSL/TLS Certificates and keys
*.pem
*.key
*.crt
*.cert
*.cer
letsencrypt/
certs/
ssl/

# SSH keys
*.pub
id_rsa
id_dsa
id_ecdsa
id_ed25519
.ssh/

# Runtime data directories
config/
data/
db/
logs/
*.log
state/

# Docker volumes
volumes/

# Service-specific data (not tracked)

# Proxy
proxy/data/
proxy/letsencrypt/
proxy/etc-pihole/
proxy/etc-dnsmasq.d/
proxy/ddns/data/
proxy/*.env

# Dashboard
dashboard/configs/
dashboard/data/
dashboard/icons/
dashboard/imgs/
dashboard/beszel_data/
dashboard/beszel_agent_data/
dashboard/beszel_socket/
dashboard/beszel_agent_data/
dashboard/*.env

# IT Tools
ittools/config/
ittools/ssl/
ittools/wazuh-docker/
ittools/*.env

# Nextcloud
nextcloud/config/
nextcloud/data/
nextcloud/db/
nextcloud/nextcloud.env
nextcloud/old/
nextcloud/*.env

# Media
media/transmission/
media/config/
media/overseer/config/
media/plex/config/
media/immich/
media/*.env

# Syncthing
syncthing/config/
syncthing/*.env

# Minecraft
minecraft/world/
minecraft/server.properties
minecraft/*.env

# Cloud (future/new)
cloud/*/
cloud/*.env

# Backups
backups/
*.tar
*.tar.gz
*.zip
*.bak
*_backup.*

# Large media files
*.iso
*.img
*.dmg

# Local development & IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node modules
node_modules/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# Docker compose overrides
docker-compose.override.yml

# Temporary files
.tmp/
temp/
*.tmp

# PID files
*.pid

# Logs
npm-debug.log
yarn-error.log
