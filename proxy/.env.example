# Nginx Proxy Manager, Pi-hole, DDNS - Environment Variables
# Copy to .env in this directory and update with your values

# Networking
NPM_IP=192.168.0.198
PIHOLE_IP=192.168.0.198

# Timezone
TZ=Europe/Lisbon

# ========== Pi-hole ==========
PIHOLE_PASSWORD=change_me_to_strong_password

# ========== DDNS Updater (DuckDNS) ==========
DUCKDNS_DOMAIN=your-subdomain.duckdns.org
DUCKDNS_TOKEN=your_duckdns_token_here
